# ============================================
# CONFIGURACIÓN DE IMPERIOHUB APP
# ============================================

# URL de la API del backend
# En desarrollo local: http://localhost:3000/api
# En producción: https://tu-backend.com/api
API_URL=http://localhost:3000/api

# ============================================
# GOOGLE OAUTH CREDENTIALS
# ============================================
# Estos valores se obtienen desde Google Cloud Console
# https://console.cloud.google.com/apis/credentials

# Web Client ID (REQUERIDO)
# Este es el Client ID de tipo "Web application"
# Se usa tanto en Android como en iOS para validar con el backend
GOOGLE_WEB_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# iOS Client ID (REQUERIDO para iOS)
# Este es el Client ID de tipo "iOS"
# Solo se usa en la configuración de iOS
GOOGLE_IOS_CLIENT_ID=tu-ios-client-id.apps.googleusercontent.com

# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# 1. Para Android:
#    - Solo necesitas GOOGLE_WEB_CLIENT_ID
#    - Debes agregar el SHA-1 y SHA-256 de tu keystore en Google Cloud Console
#    - Comando para obtener SHA-1:
#      keytool -list -v -keystore android/app/debug.keystore -alias androiddebugkey
#      (password por defecto: android)
#
# 2. Para iOS:
#    - Necesitas GOOGLE_IOS_CLIENT_ID y GOOGLE_WEB_CLIENT_ID
#    - El iOS Client ID debe tener el Bundle ID de tu app (com.imperiohub.app)
#
# 3. Después de crear este archivo:
#    - Copia este archivo como .env
#    - Reemplaza los valores con tus credenciales reales
#    - NO SUBAS el archivo .env a git (debe estar en .gitignore)
